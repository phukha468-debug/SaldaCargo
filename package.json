{
  "name": "saldacargo",
  "version": "0.1.0",
  "private": true,
  "description": "Система управления транспортным бизнесом — MiniApp в МАХ + Web Dashboard",
  "packageManager": "pnpm@10.33.1",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,yaml,yml}\"",
    "gen:types": "supabase gen types typescript --local > packages/shared-types/src/database.types.ts",
    "seed:generate": "tsx scripts/generate-seed-from-md.ts",
    "seed:apply": "tsx scripts/apply-seed.ts",
    "deploy:web": "cd apps/web && vercel --prod",
    "deploy:miniapp": "cd apps/miniapp && vercel --prod",
    "deploy:all": "pnpm deploy:web && pnpm deploy:miniapp",
    "prepare": "husky"
  },
  "devDependencies": {
    "@supabase/supabase-js": "^2.105.1",
    "@types/node": "^20.11.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.1",
    "dotenv": "^17.4.2",
    "eslint": "^9.39.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.2.5",
    "supabase": "^2.95.6",
    "tsx": "^4.7.1",
    "turbo": "^2.0.3",
    "typescript": "^5.4.5",
    "vercel": "^52.2.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.33.1"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "supabase"
    ]
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,jsx,mjs,cjs}": [
      "prettier --write"
    ],
    "*.{json,md,yaml,yml,css}": [
      "prettier --write"
    ]
  }
}
