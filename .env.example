# ============================================================
# SUPABASE (Database & Auth)
# ============================================================
# NEXT_PUBLIC_* = доступны на клиенте (браузере)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Только на сервере (API Routes). Обходит RLS!
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================
# MAX SDK (Mini App)
# ============================================================
NEXT_PUBLIC_MAX_BOT_TOKEN=123456789:ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefgh
NEXT_PUBLIC_MAX_APP_ID=com.saldacargo.miniapp

# ============================================================
# EXTERNAL APIs
# ============================================================
# Опти24 (топливные карты)
OPTI24_API_KEY=sk_live_xxxxx

# Wialon (GPS мониторинг)
WIALON_API_TOKEN=xxxxx

# Sentry (логирование ошибок)
SENTRY_DSN=https://xxxxx@xxxxx.ingest.sentry.io/xxxxx

# ============================================================
# APP CONFIGURATION
# ============================================================
# development | staging | production
NEXT_PUBLIC_APP_ENV=development

# URL для внутренних API вызовов
NEXT_PUBLIC_API_URL=http://localhost:3000

# Версия приложения
NEXT_PUBLIC_VERSION=1.0.0

# ============================================================
# VERCEL (CI/CD)
# ============================================================
VERCEL_TOKEN=xxxxx
VERCEL_ORG_ID=xxxxx
VERCEL_PROJECT_ID_WEB=xxxxx
VERCEL_PROJECT_ID_MINIAPP=xxxxx
